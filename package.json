{
  "name": "atproto-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create atproto-pds",
    "db:init": "wrangler d1 execute atproto-pds --file=schema.sql",
    "db:init:local": "wrangler d1 execute atproto-pds --local --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.47.0"
  }
}